# Telegram Bot Configuration
# بيانات إعدادات بوت Telegram

# Telegram Bot Token - احصل عليه من @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here_paste_your_actual_token

# Djezzy API Configuration (Optional)
# This can be extended if needed
DJEZZY_MAX_ATTEMPTS=50
DJEZZY_TIMEOUT=10
DJEZZY_RETRY_DELAY=1

# Logging Configuration (Optional)
LOG_LEVEL=INFO
LOG_FILE=djezzy_tool.log

# Environment Mode
# استخدم: development أو production
ENVIRONMENT=development

# Database Configuration (if using database)
# استخدم هذا إذا كنت تريد حفظ البيانات في قاعدة بيانات
DATABASE_URL=optional_database_url

# API Configuration (Advanced)
API_TIMEOUT=10
API_RETRIES=3
API_RETRY_DELAY=1
